# Supabase — get from https://supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for guest / platform-key queries (set in Vercel → Environment Variables).
# Do not commit real values; rotate any key that was ever pushed to git.
PLATFORM_AHREFS_KEY=
